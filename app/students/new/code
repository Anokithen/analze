import { Input } from "@hugeicons/core-free-icons"
import axios from "axios"
import { useState } from "react"

export default function CodeAnalze(){
    const[formData,setFormData] = useState({age: "",
      cgpa: "",
      created_at: "",
      email: "",
      full_name: "",
      is_active: true,
      joined_date: ""})

    
    const createStudent = async() =>{
        try{
            const  response = await axios.post(
                `https://jey-student-api.up.railway.app/api/students`,{
                    age:Number(formData.age),
                    cgpa: Number(formData.cgpa),
                    created_at: formData.created_at,
                    email: formData.email,
                    full_name: formData.full_name,
                    is_active: formData.is_active,
                    joined_date: formData.joined_date
                }
            )
            console.log("student succcessfull",response.data)
            alert("student created successfull")

            setFormData({age: "",
      cgpa: "",
      created_at: "",
      email: "",
      full_name: "",
      is_active: true,
      joined_date: ""})
        } catch (error){
            console.error("error is",error)
        }
    }

    return(<>
<div>
     <input
          type="text"
          placeholder="Full Name"
          value={formData.full_name}
          onChange={(e) =>
            setFormData({ ...formData, full_name: e.target.value })
          }
          className="w-full rounded border p-2"
        />

</div>

    </>)
}